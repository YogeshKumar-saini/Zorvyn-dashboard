{
  "name": "zorvyn-finance-backend",
  "version": "1.0.0",
  "description": "Industrial-grade Finance Data Processing & Role-Based Access Control Backend",
  "main": "dist/app.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev":         "ts-node-dev --respawn --transpile-only src/app.ts",
    "build":       "tsc --project tsconfig.json",
    "start":       "node dist/app.js",

    "db:migrate":  "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed":     "ts-node prisma/seed.ts",
    "db:studio":   "prisma studio",
    "db:reset":    "prisma migrate reset --force && ts-node prisma/seed.ts",
    "db:deploy":   "prisma migrate deploy",

    "test":        "vitest run",
    "test:watch":  "vitest",
    "test:cover":  "vitest run --coverage",

    "lint":        "eslint src --ext .ts --max-warnings 0",
    "lint:fix":    "eslint src --ext .ts --fix",
    "format":      "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "format:check":"prettier --check \"src/**/*.ts\""
  },
  "keywords": ["finance", "backend", "express", "prisma", "rbac", "typescript"],
  "author": "Zorvyn",
  "license": "MIT",
  "dependencies": {
    "@prisma/client":      "^5.10.2",
    "bcryptjs":            "^2.4.3",
    "compression":         "^1.7.4",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.18.3",
    "express-rate-limit":  "^7.2.0",
    "helmet":              "^7.1.0",
    "jsonwebtoken":        "^9.0.2",
    "pino":                "^8.19.0",
    "pino-http":           "^9.0.0",
    "swagger-jsdoc":       "^6.2.8",
    "swagger-ui-express":  "^5.0.0",
    "uuid":                "^9.0.1",
    "zod":                 "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":          "^2.4.6",
    "@types/compression":       "^1.7.5",
    "@types/cors":              "^2.8.17",
    "@types/express":           "^4.17.21",
    "@types/jsonwebtoken":      "^9.0.6",
    "@types/morgan":            "^1.9.9",
    "@types/node":              "^20.11.30",
    "@types/supertest":         "^6.0.2",
    "@types/swagger-jsdoc":     "^6.0.4",
    "@types/swagger-ui-express":"^4.1.6",
    "@types/uuid":              "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":        "^7.0.0",
    "eslint":                   "^8.57.0",
    "eslint-plugin-import":     "^2.29.1",
    "pino-pretty":              "^11.0.0",
    "prettier":                 "^3.2.5",
    "prisma":                   "^5.10.2",
    "supertest":                "^6.3.4",
    "ts-node":                  "^10.9.2",
    "ts-node-dev":              "^2.0.0",
    "typescript":               "^5.4.2",
    "vitest":                   "^1.4.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
