# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/zorvyn?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — Generate a strong secret: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
